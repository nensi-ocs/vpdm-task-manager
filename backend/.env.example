DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/vpdm_daily_task
PORT=3001

# Required for auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
# Optional (default 7d)
# JWT_EXPIRES_IN=7d

# After changing prisma/schema.prisma:
#   cd backend && npm run prisma:migrate
# Deploy / CI:
#   cd backend && npm run prisma:migrate:deploy
