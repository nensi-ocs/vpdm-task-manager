# Use the user + database from your host (e.g. Hostinger PostgreSQL panel). P1010 = that user needs GRANT on DB + schema public.
DATABASE_URL=postgresql://YOUR_DB_USER:YOUR_PASSWORD@YOUR_PG_HOST:5432/vpdm_task_manager
PORT=3001

# Browser origins allowed to call the API (comma-separated). Must include your live site, e.g. https://app.vpdm.cloud
CORS_ORIGINS=https://app.vpdm.cloud,http://localhost:5173,http://127.0.0.1:5173

# Required for auth (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
# Optional (default 7d)
# JWT_EXPIRES_IN=7d

# After changing prisma/schema.prisma:
#   cd backend && npm run prisma:migrate
# Deploy / CI:
#   cd backend && npm run prisma:migrate:deploy
